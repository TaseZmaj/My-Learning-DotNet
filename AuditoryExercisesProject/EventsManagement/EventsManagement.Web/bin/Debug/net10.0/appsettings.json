{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost\\SQLEXPRESS;Database=EventsDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "MySecretKeyThatIsAtleast32CharsLong!",
    "Issuer": "EventsManagement",
    "Audience": "EventsManagement"
  },
  
  "WeatherApi":{
    "BaseUrl": "https://api.openweathermap.org/data/2.5/",
    "TimeoutSeconds": 30,
    "cacheDurationMinutes":120
  },
  "ExternalEventApi": {
    "BaseUrl": "https://api.example.com/",
    "TokenUrl": "https://auth.example.com/oauth/token",
    "Scope": "events.read venues.read",
    "ClientId": "placeholder",
    "ClientSecret": "placeholder",
    "TimeoutSeconds": 30
  }
}
